authorization.sources = [
  {
    type = redis
    server = "redis.example.com:6379"
    redis_type = single
    pool_size = 8
    username = "user"
    password = "secret"
    database = 0
    ssl = {
      #substruct(emqx:ssl_client_opts)
    }
    cmd = "HGETALL authz"
    compatibility_mode = disabled
  }
]