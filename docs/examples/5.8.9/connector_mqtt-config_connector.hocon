connectors.mqtt.my_connector {
  pool_size = 8
  resource_opts = {
    #substruct(connector_mqtt:resource_opts)
  }
  server = "broker.example.com:1883"
  clientid_prefix = <<"clientid_prefix">>
  static_clientids = []
  proto_ver = v4
  bridge_mode = false
  username = <<"user">>
  password = "secret"
  clean_start = true
  keepalive = "160s"
  connect_timeout = "10s"
  retry_interval = "15s"
  max_inflight = 32
  ssl = {
    #substruct(emqx:ssl_client_opts)
  }
}