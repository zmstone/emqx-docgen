connectors.confluent_producer.my_confluent_1.ssl {
  cacertfile = "/etc/certs/ca-bundle.pem"
  certfile = "/etc/certs/client-chain.pem"
  keyfile = "/etc/certs/client-key.pem"
  reuse_sessions = true
  depth = 10
  password = "secret_password"
  versions = ["tlsv1.3", "tlsv1.2"]
  ciphers = []
  secure_renegotiate = true
  log_level = notice
  hibernate_after = "5s"
  partial_chain = false
  verify_peer_ext_key_usage = "serverAuth"
  server_name_indication = auto
}