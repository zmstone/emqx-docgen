connectors.kafka_consumer.my_kafka_consumer_1.ssl {
  cacertfile = "path/to/ca.pem"
  certfile = "path/to/cert.pem"
  keyfile = "path/to/key.pem"
  verify = verify_none
  reuse_sessions = true
  depth = 10
  password = "secret"
  versions = ["tlsv1.3", "tlsv1.2"]
  ciphers = []
  secure_renegotiate = true
  log_level = notice
  hibernate_after = "5s"
  partial_chain = false
  verify_peer_ext_key_usage = "serverAuth,OID:1.3.6.1.5.5.7.3.2"
  enable = false
  server_name_indication = auto
}