authorization.sources = [
  {
    type = mongodb
    collection = "authz_collection"
    filter = {}
    limit = 1000
    skip = 0
    mongo_type = single
    server = "127.0.0.1:27017"
    w_mode = unsafe
    srv_record = false
    pool_size = 8
    username = "db_user"
    password = "secret"
    use_legacy_protocol = auto
    auth_source = "admin"
    database = "authz_db"
    topology = {
      #substruct(mongo:topology)
    }
    ssl = {
      #substruct(emqx:ssl_client_opts)
    }
  }
]