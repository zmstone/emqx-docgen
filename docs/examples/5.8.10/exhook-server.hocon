exhook.servers = [
  {
    name = "my_exhook_server"
    url = "https://grpc.example.com"
    request_timeout = "5s"
    failed_action = deny
    ssl = {
      #substruct(exhook:ssl_conf)
    }
    socket_options = {
      #substruct(exhook:socket_options)
    }
    auto_reconnect = "60s"
    pool_size = 8
  }
]