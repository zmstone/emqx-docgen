gateway.exproto.listeners.tcp.my_listener_1 {
  acceptors = 16
  tcp_options = {
    #substruct(emqx:tcp_opts)
  }
  proxy_protocol = false
  proxy_protocol_timeout = "3s"
  bind = "0.0.0.0:1883"
  max_connections = 1024
  max_conn_rate = 1000
  enable_authn = true
  mountpoint = "some_tenant/${clientid}"
  access_rules = ["deny 192.168.1.1", "allow 192.168.1.0/24", "deny all"]
}